#!/usr/bin/env bash
watch_file .envrc
watch_file flake/common.nix
watch_file nix/apps.nix
watch_file nix/devshell.nix
watch_file nix/git-hooks.nix
watch_file nix/treefmt.nix

case "$(uname -s)" in
Darwin)
    watch_file flake/darwin/flake.nix
    watch_file flake/darwin/flake.lock
    ;;
Linux)
    watch_file flake/linux/flake.nix
    watch_file flake/linux/flake.lock
    ;;
esac

# Suppress noisy nix-direnv info logs while keeping manual reload warnings.
type _nix_direnv_info >/dev/null 2>&1 && _nix_direnv_info() {
    :
}

# Keep manual reload behavior for nix-direnv cache updates.
type nix_direnv_manual_reload >/dev/null 2>&1 && nix_direnv_manual_reload
use flake . --impure
