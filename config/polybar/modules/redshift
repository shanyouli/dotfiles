#!/usr/bin/env bash

# Specifying the icon(s) in the script
# This allows us to change its appearance conditionally
pgrep redshift &> /dev/null
if [[ $? -eq 0 ]]; then
    temp=$(redshift -p 2>/dev/null | grep temp | cut -d' ' -f3)
    temp=${temp//K/}
fi

icon="ŅŁČ"
# OPTIONAL: Append ' ${temp}K' after $icon
if [[ -z $temp ]]; then
    grey=$(xrdb -query | grep "\.color240" | cut -f2)
    echo "%{F$grey}$icon"       # Greyed out (not running)
elif [[ $temp -ge 5000 ]]; then
    blue=$(xrdb -query | grep "\.color4" | cut -f2)
    echo "%{F$blue}$icon"       # Blue
elif [[ $temp -ge 4000 ]]; then
    yello=$(xrdb -query | grep "\.color3" | cut -f2)
    echo "%{F$yello}$icon"       # Yellow
else
    red=$(xrdb -query | grep "\.color1" | cut -f2)
    echo "%{F$red}$icon"       # Orange
fi
