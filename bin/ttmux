#!/usr/bin/env bash
# Toggle a tmux terminal window.

TMUX_NAME=ttmux
if command -v tmuxifier >/dev/null ; then
    TMUX_CMD=${1:-'unset TMUX ; tmuxifier load-session main'}
else
    TMUX_CMD=${1:-'tmux new-session -A -s main -n main'}
fi
TERMINAL=${TERMINAL:-xst}

TMUX_ID=$(wmctrl -l | grep "$TMUX_NAME$" | cut -d" " -f1)
if [[ -n $TMUX_ID ]]; then
    exec wmctrl -i -a $TMUX_ID
else
    case $TERMINAL in
        xst|st)
            exec $TERMINAL -t $TMUX_NAME -n $TMUX_NAME -c $TMUX_NAME \
                -e $SHELL -c "$TMUX_CMD" & ;;
        urxvt) exec $TERMINAL -name $TMUX_NAME -e $SHELL -c "$TMUX_CMD" & ;;
        *) exec $TERMINAL -t $TMUX_NAME -e $SHELL -c "$TMUX_CMD" & ;;
    esac
    if command -v bspc >/dev/null && bspc wm --get-status >/dev/null ; then
        bspc desktop -f 7
    fi
fi
