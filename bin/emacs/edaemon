#!/usr/bin/env bash
#

INPUT_METHOD=${_EMACS_USING_INPUT:-fcitx}
# Fix incompatible terminals that cause odd 'not a valid terminal' errors
[[ $TERM = "alacritty" ]] && export TERM=xterm-256color

#Judging whether the input method is used
case $INPUT_METHOD  in
    "rime") unset GTK_IM_MODULE QT_IM_MODULE XMODIFIERS ;;
    "fcitx") fcitx-remote >/dev/null || fcitx -d && sleep 1 ;;
    "*") >&2 echo "No support other options. \
        Plese set _EMACS_USING_INPUT 'fcitx' or 'rime'" ;; 
esac

[[ -f /run/user/$UID/main ]] && rm -rf /run/user/$UID/main
emacs --daemon="main" >/dev/null
