#!/usr/bin/env bash
#
ECRID=org-protocol
focused=$(xdotool getactivewindow)
scratch=$(xdotool search --onlyvisible --name $ECRID)

if ! emacsclient --socket-name="main" --suppress-output --eval nil; then
    CURDIR=$(dirname $(readlink -f "$0"))
    source $CURDIR/edaemon
fi


if [[ -n $scratch ]]; then
    if [[ $focused == $scratch ]]; then
        xdotool windowkill $scratch
    else
        xdotool windowactivate $scratch
    fi
else
    exec emacsclient -a "" -c -F "((name . \"$ECRID\"))" --socket-name="main" "$@"
fi
